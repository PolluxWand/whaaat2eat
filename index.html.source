    <style>
        /* Base Styles */
        body {
            background-color: #f5f5f5;
            color: #000000;
            -webkit-tap-highlight-color: transparent;
            overscroll-behavior: none;
            transition: background-color 0.3s ease, color 0.3s ease;
            min-height: 100vh;
        }
        
        .dark body {
            background-color: #000000;
            color: #ffffff;
        }

        .app-shell {
            height: 100svh;
            min-height: 100svh;
            overflow-x: hidden;
            overflow-y: hidden;
        }

        @media (min-width: 500px) {
            body {
                background:
                    radial-gradient(circle at 50% 0%, rgba(255,255,255,0.12), transparent 32rem),
                    #050505;
            }

            .app-shell {
                height: calc(100dvh - 40px);
                min-height: calc(100dvh - 40px);
                margin-block: 20px;
                border-radius: 28px;
                border: 1px solid rgba(255,255,255,0.08);
            }
        }

        .app-shell::after {
            content: "";
            position: absolute;
            inset: 0;
            pointer-events: none;
            background-image: linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px);
            background-size: 100% 7px;
            opacity: 0.35;
            mix-blend-mode: soft-light;
        }

        .scrollbar-hide::-webkit-scrollbar { display: none; }
        .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
        .nav-scrollbar {
            scrollbar-width: thin;
            scrollbar-color: rgba(113, 113, 122, 0.55) transparent;
            touch-action: pan-x;
        }
        .nav-scrollbar::-webkit-scrollbar { height: 4px; }
        .nav-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .nav-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(113, 113, 122, 0.55);
            border-radius: 999px;
        }

        .ios-glass {
            background: linear-gradient(135deg, rgba(255,255,255,0.72), rgba(255,255,255,0.48));
            border: 1px solid rgba(24,24,27,0.10);
            box-shadow:
                inset 0 1px 0 rgba(255,255,255,0.58),
                0 18px 48px rgba(0,0,0,0.16);
            -webkit-backdrop-filter: blur(22px) saturate(1.45);
            backdrop-filter: blur(22px) saturate(1.45);
        }

        .dark .ios-glass {
            background: linear-gradient(135deg, rgba(34,34,40,0.66), rgba(12,12,16,0.48));
            border-color: rgba(255,255,255,0.15);
            box-shadow:
                inset 0 1px 0 rgba(255,255,255,0.12),
                0 18px 54px rgba(0,0,0,0.38);
        }

        .ios-glass-soft {
            background: linear-gradient(135deg, rgba(255,255,255,0.68), rgba(255,255,255,0.38));
            border: 1px solid rgba(24,24,27,0.10);
            box-shadow:
                inset 0 1px 0 rgba(255,255,255,0.52),
                0 10px 28px rgba(0,0,0,0.14);
            -webkit-backdrop-filter: blur(18px) saturate(1.35);
            backdrop-filter: blur(18px) saturate(1.35);
        }

        .dark .ios-glass-soft {
            background: linear-gradient(135deg, rgba(255,255,255,0.17), rgba(255,255,255,0.07));
            border-color: rgba(255,255,255,0.15);
            box-shadow:
                inset 0 1px 0 rgba(255,255,255,0.12),
                0 10px 28px rgba(0,0,0,0.28);
        }

        .ios-glass-input {
            background: linear-gradient(135deg, rgba(255,255,255,0.70), rgba(255,255,255,0.38));
            border: 1px solid rgba(24,24,27,0.14);
            box-shadow:
                inset 0 1px 0 rgba(255,255,255,0.55),
                0 16px 44px rgba(0,0,0,0.15);
            -webkit-backdrop-filter: blur(24px) saturate(1.45);
            backdrop-filter: blur(24px) saturate(1.45);
        }

        .dark .ios-glass-input {
            background: linear-gradient(135deg, rgba(18,18,24,0.66), rgba(0,0,0,0.42));
            border-color: rgba(255,255,255,0.28);
            box-shadow:
                inset 0 1px 0 rgba(255,255,255,0.10),
                0 18px 58px rgba(0,0,0,0.46);
        }

        .ios-nav-active {
            background: rgba(255,255,255,0.92);
            color: #09090b;
            border-color: rgba(255,255,255,0.84);
            box-shadow: 0 8px 20px rgba(0,0,0,0.16), inset 0 1px 0 rgba(255,255,255,0.72);
        }

        .dark .ios-nav-active {
            background: rgba(255,255,255,0.90);
            color: #09090b;
            border-color: rgba(255,255,255,0.76);
        }

        .ios-icon-button {
            color: rgba(39,39,42,0.78);
        }

        .dark .ios-icon-button {
            color: rgba(244,244,245,0.88);
        }

        .wheel-frame {
            width: min(92dvw, 402px);
            max-width: calc(100% - 12px);
            aspect-ratio: 1 / 1;
        }

        .wheel-zone {
            width: 100%;
            min-height: 0;
        }

        .wheel-action-rail {
            position: absolute;
            left: 0;
            right: 0;
            bottom: 10px;
            z-index: 25;
            display: flex;
            justify-content: space-between;
            padding-inline: 24px;
            pointer-events: none;
        }

        .wheel-action-rail > button {
            pointer-events: auto;
        }

        .wheel-pointer {
            position: absolute;
            top: -10px;
            left: 50%;
            width: 24px;
            height: 42px;
            transform: translateX(-50%);
            z-index: 30;
            pointer-events: none;
            filter: drop-shadow(0 8px 12px rgba(0,0,0,0.24));
        }

        .dark .wheel-pointer {
            filter: drop-shadow(0 8px 14px rgba(0,0,0,0.52));
        }

        .top-menu-popover {
            position: absolute;
            top: 0;
            right: 48px;
            z-index: 35;
            display: flex;
            gap: 8px;
            padding: 4px;
            border-radius: 999px;
            transform-origin: top right;
        }

        .app-header-grid {
            display: grid;
            grid-template-columns: 84px minmax(0, 1fr) 36px;
            align-items: center;
            column-gap: 7px;
        }

        .result-panel {
            max-height: calc(100svh - 24px);
            overflow-y: auto;
            scrollbar-width: none;
        }

        .result-panel::-webkit-scrollbar {
            display: none;
        }

        .result-theme-dot {
            width: 24px;
            height: 24px;
            border-radius: 999px;
            border: 1px solid rgba(255,255,255,0.52);
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.45), 0 8px 22px rgba(0,0,0,0.18);
            transition: transform 0.18s ease, opacity 0.18s ease, outline-color 0.18s ease;
        }

        .result-theme-dot[aria-pressed="true"] {
            outline: 2px solid rgba(255,255,255,0.88);
            outline-offset: 3px;
            transform: scale(1.08);
            opacity: 1;
        }

        .result-theme-dot[aria-pressed="false"] {
            opacity: 0.58;
        }

        .poster-preview {
            border-radius: 18px;
            border: 1px solid rgba(24,24,27,0.10);
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.35), 0 12px 28px rgba(0,0,0,0.16);
            transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
        }

        .poster-preview-white {
            background: #ffffff;
            color: #09090b;
            border-color: rgba(24,24,27,0.10);
        }

        .poster-preview-black {
            background: #09090b;
            color: #ffffff;
            border-color: rgba(255,255,255,0.16);
        }

        .poster-preview-red {
            background: linear-gradient(135deg, #ef4444 0%, #b91c1c 100%);
            color: #fffbeb;
            border-color: rgba(254,202,202,0.35);
        }

        .modal-backdrop {
            background: rgba(0,0,0,0.72);
            -webkit-backdrop-filter: blur(20px) saturate(1.25);
            backdrop-filter: blur(20px) saturate(1.25);
        }

        .modal-panel {
            max-height: calc(100svh - 24px);
            border-radius: 28px;
            overflow: hidden;
        }

        .modal-scroll {
            overflow-y: auto;
            scrollbar-width: none;
        }

        .modal-scroll::-webkit-scrollbar {
            display: none;
        }

        .modal-title {
            font-size: 17px;
            font-weight: 900;
            letter-spacing: 0;
        }

        .modal-close {
            width: 34px;
            height: 34px;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .modal-field {
            width: 100%;
            border-radius: 16px;
            background: rgba(255,255,255,0.58);
            border: 1px solid rgba(24,24,27,0.10);
            outline: none;
            color: #09090b;
            transition: border-color 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
        }

        .dark .modal-field {
            background: rgba(255,255,255,0.08);
            border-color: rgba(255,255,255,0.12);
            color: #fafafa;
        }

        .modal-field:focus {
            border-color: rgba(255,255,255,0.58);
            box-shadow: 0 0 0 2px rgba(255,255,255,0.18);
        }

        .modal-tile {
            background: rgba(255,255,255,0.48);
            border: 1px solid rgba(24,24,27,0.10);
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.44);
        }

        .dark .modal-tile {
            background: rgba(255,255,255,0.07);
            border-color: rgba(255,255,255,0.12);
        }

        .modal-primary {
            background: #09090b;
            color: white;
            border-radius: 18px;
            font-weight: 900;
            box-shadow: 0 14px 36px rgba(0,0,0,0.24);
            transition: transform 0.18s ease, opacity 0.18s ease;
        }

        .dark .modal-primary {
            background: white;
            color: #09090b;
        }

        .modal-primary:active,
        .modal-secondary:active {
            transform: scale(0.98);
        }

        .modal-secondary {
            border-radius: 18px;
            font-weight: 800;
            transition: transform 0.18s ease, opacity 0.18s ease;
        }

        @media (max-height: 590px) {
            .result-panel {
                padding: 16px !important;
            }

            .modal-panel {
                max-height: calc(100svh - 16px);
            }

            .result-icon {
                font-size: 64px !important;
                margin-bottom: 8px !important;
            }

            .result-title {
                font-size: 28px !important;
            }

            .result-description {
                margin-bottom: 14px !important;
                line-height: 1.45 !important;
            }
        }

        @media (min-width: 500px) {
            .wheel-frame {
                width: min(calc(100% - 18px), 402px);
            }
        }

        @media (max-height: 680px) {
            .wheel-frame {
                width: min(calc(100% - 8px), 372px);
            }

            .compact-header {
                padding-top: 10px;
            }

            .compact-title {
                font-size: 24px;
            }

            .compact-subtitle {
                display: none;
            }

            .compact-search {
                margin-top: 0;
                padding-left: 0 !important;
                padding-right: 0 !important;
                min-width: 0;
            }

            .compact-search-input {
                padding-top: 5px;
                padding-bottom: 5px;
                padding-left: 2rem !important;
                padding-right: 2rem !important;
                font-size: 12px;
                border-radius: 999px;
            }

            .compact-nav {
                margin-top: 6px;
            }

            .compact-nav-button {
                padding-top: 4px;
                padding-bottom: 4px;
            }

            .compact-wheel-zone {
                padding-top: 0;
                padding-bottom: 2px;
            }

            .compact-footer {
                margin-top: 0 !important;
                padding-bottom: 12px !important;
                gap: 0 !important;
            }

            .compact-spin-button {
                padding-top: 10px !important;
                padding-bottom: 10px !important;
            }

            .wheel-action-rail {
                bottom: 8px;
                padding-inline: 18px;
            }
        }
        
        /* Sticker Effect */
        .sticker-effect {
            filter: 
                drop-shadow(0px -2px 0px white) 
                drop-shadow(2px 0px 0px white) 
                drop-shadow(0px 2px 0px white) 
                drop-shadow(-2px 0px 0px white)
                drop-shadow(0 4px 8px rgba(0,0,0,0.5));
            transition: transform 0.3s ease;
        }
        .sticker-effect:active { transform: scale(0.95); }

        /* Loader */
        .loader {
            border: 3px solid #e5e5e5;
            border-top: 3px solid #000;
            border-radius: 50%;
            width: 30px;
            height: 30px;
            animation: spin 1s linear infinite;
        }
        .dark .loader {
            border: 3px solid #333;
            border-top: 3px solid #fff;
        }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
        
        #loading-screen {
            position: fixed; inset: 0; background: #fff; z-index: 9999;
            display: flex; justify-content: center; align-items: center; transition: opacity 0.5s;
        }
        .dark #loading-screen { background: #000; }

        @media (prefers-reduced-motion: reduce) {
            *, *::before, *::after {
                animation-duration: 0.01ms !important;
                animation-iteration-count: 1 !important;
                scroll-behavior: auto !important;
                transition-duration: 0.01ms !important;
            }
        }
    </style>
</head>
<body>
    <div id="loading-screen"><div class="loader"></div></div>
    <div id="root"></div>

    <script type="text/babel">
        // --- 0. PREAMBLE & UTILS ---
        const { useState, useEffect, useRef, useMemo, useCallback } = React;
        
        // Hide loader
        setTimeout(() => {
            const el = document.getElementById('loading-screen');
            if(el) { el.style.opacity = '0'; setTimeout(()=>el.remove(), 500); }
        }, 500);

        // --- AUDIO ENGINE (Realistic Ratchet) ---
        const AudioEngine = {
            ctx: null,
            init: () => {
                if (!AudioEngine.ctx) {
                    const AudioContext = window.AudioContext || window.webkitAudioContext;
                    if (AudioContext) AudioEngine.ctx = new AudioContext();
                }
            },
            resume: () => {
                if (AudioEngine.ctx && AudioEngine.ctx.state === 'suspended') {
                    AudioEngine.ctx.resume();
                }
            },
            // Generate a short burst of white noise (Click)
            playClick: () => {
                if (!AudioEngine.ctx) AudioEngine.init();
                AudioEngine.resume();
                if (!AudioEngine.ctx) return;

                try {
                    const t = AudioEngine.ctx.currentTime;
                    const bufferSize = AudioEngine.ctx.sampleRate * 0.015; // 15ms burst
                    const buffer = AudioEngine.ctx.createBuffer(1, bufferSize, AudioEngine.ctx.sampleRate);
                    const data = buffer.getChannelData(0);

                    for (let i = 0; i < bufferSize; i++) {
                        data[i] = (Math.random() * 2 - 1) * 0.8;
                    }

                    const noise = AudioEngine.ctx.createBufferSource();
                    noise.buffer = buffer;

                    const filter = AudioEngine.ctx.createBiquadFilter();
                    filter.type = 'highpass';
                    filter.frequency.value = 1200;

                    const gain = AudioEngine.ctx.createGain();
                    gain.gain.setValueAtTime(0.3, t);
                    gain.gain.exponentialRampToValueAtTime(0.001, t + 0.01);

                    noise.connect(filter);
                    filter.connect(gain);
                    gain.connect(AudioEngine.ctx.destination);

                    noise.start(t);
                } catch(e) {
                    console.error('音效播放失败:', e);
                }
            },
            playWin: () => {
                if (!AudioEngine.ctx) AudioEngine.init();
                AudioEngine.resume();
                if (!AudioEngine.ctx) return;

                try {
                    const t = AudioEngine.ctx.currentTime;

                    const osc = AudioEngine.ctx.createOscillator();
                    const gain = AudioEngine.ctx.createGain();

                    osc.type = 'sine';
                    osc.frequency.setValueAtTime(880, t); // A5

                    gain.gain.setValueAtTime(0, t);
                    gain.gain.linearRampToValueAtTime(0.2, t + 0.01);
                    gain.gain.exponentialRampToValueAtTime(0.001, t + 1.5);

                    osc.connect(gain);
                    gain.connect(AudioEngine.ctx.destination);
                    osc.start(t);
                    osc.stop(t + 1.5);
                } catch(e) {
                    console.error('胜利音效播放失败:', e);
                }
            }
        };

        // --- ICONS ---
        const Icons = {
            Plus: (p) => <svg {...p} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>,
            BookOpen: (p) => <svg {...p} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>,
            Settings: (p) => <svg {...p} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.09a2 2 0 0 1-1-1.74v-.47a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.39a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>,
            Edit: (p) => <svg {...p} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>,
            Shuffle: (p) => <svg {...p} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M2 18h1.4c1.3 0 2.5-.6 3.3-1.7l14.2-12.7c.7-1 1.9-1.6 3.1-1.6"/><path d="M2 6h1.4c1.3 0 2.5.6 3.3 1.7l14.2 12.7c.7 1 1.9 1.6 3.1 1.6"/><path d="M19 13.5L24 18l-5 4.5"/><path d="M19 2L24 6.5l-5 4.5"/></svg>,
            History: (p) => <svg {...p} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M12 7v5l4 2"/></svg>,
            X: (p) => <svg {...p} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>,
            Layers: (p) => <svg {...p} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/></svg>,
            Utensils: (p) => <svg {...p} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="M3 2v7c0 1.1.9 2 2 2h4a2 2 0 0 0 2-2V2"/><path d="M7 2v20"/><path d="M21 15V2v0a5 5 0 0 0-5 5v6c0 1.1.9 2 2 2h3Zm0 0v7"/></svg>,
            IceCream: (p) => <svg {...p} viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="2" strokeLinecap="round" strokeLinejoin="round"><path d="m7 11 4.08 10.35a1 1 0 0 0 1.84 0L17 11"/><path d="M17 7A5 5 0 0 0 7 7"/><path d="M17 7a2 2 0 0 1 0 4H7a2 2 0 0 1 0-4"/></svg>,
