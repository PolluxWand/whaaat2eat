            { id: '484', name: '21cake', icon: '🎂', category: 'dessert', tags: ['甜品', '欧美', '甜', '蛋糕', '烘焙'], description: '精品蛋糕，黑天鹅系列，高端礼盒装。' },
            { id: '485', name: '泸溪河', icon: '🥮', category: 'dessert', tags: ['甜品', '江浙', '甜', '烘焙', '糕点'], description: '桃酥专家，酥香掉渣，传统口味。' },
            { id: '486', name: '墨茉点心局', icon: '🥮', category: 'dessert', tags: ['甜品', '通用', '甜', '烘焙', '糕点'], description: '新中式点心，麻薯系列，软糯香甜。' },
            { id: '487', name: '虎头局', icon: '🐯', category: 'dessert', tags: ['甜品', '通用', '甜', '烘焙', '糕点'], description: '国潮点心铺，麻薯面包，颜值高味道好。' },
            { id: '488', name: '酥先生', icon: '🥮', category: 'dessert', tags: ['甜品', '通用', '甜', '烘焙', '糕点'], description: '肉松小贝鼻祖，海苔口味，网红点心。' },
            { id: '489', name: '詹记甜品', icon: '🍧', category: 'dessert', tags: ['甜品', '粤闽', '甜', '港式', '冰品'], description: '港式甜品，杨枝甘露，芒果西米露。' },
            { id: '490', name: '满杯百香果', icon: '🍹', category: 'dessert', tags: ['甜品', '通用', '酸', '果茶', '冰品'], description: '百香果特饮，果肉丰富，酸甜解腻。' },
            { id: '491', name: '雪冰', icon: '🍧', category: 'dessert', tags: ['甜品', '日韩', '甜', '冰品', '刨冰'], description: '韩式绵绵冰，口感细腻，配料丰富。' },
            { id: '492', name: '贡茶甜品', icon: '🍮', category: 'dessert', tags: ['甜品', '通用', '甜', '台式', '冰品'], description: '布丁烧仙草，珍珠椰果，台式风味。' },
            { id: '493', name: '龟苓膏', icon: '🟫', category: 'dessert', tags: ['甜品', '粤闽', '清淡', '港式', '养生'], description: '传统凉茶，清热降火，配蜜糖或炼乳。' },
            { id: '494', name: '糖水铺子', icon: '🥣', category: 'dessert', tags: ['甜品', '粤闽', '甜', '港式', '汤水'], description: '广式糖水，红豆沙、绿豆沙，暖心甜品。' },
            { id: '495', name: '双皮奶', icon: '🥛', category: 'dessert', tags: ['甜品', '粤闽', '甜', '港式', '养生'], description: '顺德特色，奶皮双层，口感滑嫩，奶香浓郁。' },
            { id: '496', name: '姜撞奶', icon: '🥛', category: 'dessert', tags: ['甜品', '粤闽', '甜', '港式', '热饮'], description: '广东传统，姜汁牛奶，暖胃驱寒，嫩滑香甜。' },
            { id: '497', name: '杨枝甘露', icon: '🥭', category: 'dessert', tags: ['甜品', '粤闽', '甜', '港式', '冰品'], description: '港式经典，芒果西柚椰汁西米，清爽消暑。' },
            { id: '498', name: '芋圆仙草', icon: '🍧', category: 'dessert', tags: ['甜品', '通用', '甜', '台式', '冰品'], description: '芋圆Q弹，仙草滑嫩，配椰奶或红豆。' },
            { id: '499', name: '麻糬', icon: '🍡', category: 'dessert', tags: ['甜品', '日韩', '甜', '糯米', '糕点'], description: '日式糯米团，软糯香甜，抹茶红豆各有风味。' },
            { id: '500', name: '铜锣烧', icon: '🥞', category: 'dessert', tags: ['甜品', '日韩', '甜', '糕点', '红豆'], description: '哆啦A梦最爱，红豆馅甜而不腻，饼皮松软。' },
        ];

        // --- 2. UTILS ---
        // 模糊搜索：将用户输入转换为标签过滤
        const parseFuzzySearch = (input) => {
            if (!input || input.trim() === '') return { includeTags: [], excludeTags: [], excludeKeywords: [] };

            const inputLower = input.toLowerCase().trim();
            const includeTags = [];
            const excludeTags = [];
            const excludeKeywords = [];
            const hasColdNegative = /(?:不要|不想|别|不).{0,3}(?:冰|凉)/.test(inputLower);
            const hasSpicyNegative = /(?:不要|不想|别|不).{0,4}(?:辣|麻辣|重口)/.test(inputLower);
            const hasSweetNegative = /(?:不要|不想|别|不).{0,4}(?:甜|甜品|蛋糕|冰淇淋)/.test(inputLower);
            const hasFriedNegative = /(?:不要|不想|别|不).{0,4}(?:炸|油炸|炸鸡)/.test(inputLower);
            const hasGreasyNegative = /(?:不要|不想|别|不).{0,5}(?:油腻|腻|太油|重油|油乎乎)/.test(inputLower);
            const hasRawColdNegative = /(?:不要|不想|别|不).{0,4}(?:生冷|冷食|凉菜)/.test(inputLower);
            const negativeFoodPattern = '(?:不吃|不想吃|不要吃|别吃|忌口|不能吃|不爱吃|不爱|不要|不想|别)';
            const hasSeafoodNegative = new RegExp(`${negativeFoodPattern}.{0,5}(?:鱼|海鲜|虾|蟹|贝|生蚝|鱿鱼)`).test(inputLower);
            const hasBeefNegative = new RegExp(`${negativeFoodPattern}.{0,5}(?:牛肉|牛排|牛)`).test(inputLower);
            const hasChickenNegative = new RegExp(`${negativeFoodPattern}.{0,5}(?:鸡肉|炸鸡|鸡)`).test(inputLower);
            const hasPorkNegative = new RegExp(`${negativeFoodPattern}.{0,5}(?:猪肉|猪脚|猪肚|红烧肉|猪)`).test(inputLower);
            const hasLambNegative = new RegExp(`${negativeFoodPattern}.{0,5}(?:羊肉|羊)`).test(inputLower);
            const hasSpecificMeatNegative = hasBeefNegative || hasChickenNegative || hasPorkNegative || hasLambNegative;
            const hasMeatNegative = !hasSpecificMeatNegative && new RegExp(`${negativeFoodPattern}.{0,5}(?:肉|荤)`).test(inputLower);
            const coldPositiveKeywords = ['冰的', '凉的', '冰爽', '冰淇淋'];
            const spicyPositiveKeywords = ['微辣', '很辣', '重口', '酸爽', '火锅', '麻辣烫', '川菜', '湘菜', '韩餐'];
            const sweetPositiveKeywords = ['甜', '甜品', '蛋糕', '冰淇淋', '下午茶'];
            const friedPositiveKeywords = ['炸'];
            const seafoodPositiveKeywords = ['鱼', '海鲜'];
            const meatPositiveKeywords = ['肉'];

            const addExcludeTag = (tag) => {
                if (!excludeTags.includes(tag)) excludeTags.push(tag);
                const includeIndex = includeTags.indexOf(tag);
                if (includeIndex >= 0) includeTags.splice(includeIndex, 1);
            };

            const addIncludeTag = (tag) => {
                if (!excludeTags.includes(tag) && !includeTags.includes(tag)) includeTags.push(tag);
            };

            const addExcludeKeyword = (keyword) => {
                if (keyword && !excludeKeywords.includes(keyword)) excludeKeywords.push(keyword);
            };

            if (hasColdNegative) {
                ['冰品', '生冷'].forEach(addExcludeTag);
                ['热饮', '汤水', '汤面', '汤饭'].forEach(addIncludeTag);
            }
            if (hasSpicyNegative) {
                ['辣', '重口'].forEach(addExcludeTag);
                ['辣', '麻辣', '香辣'].forEach(addExcludeKeyword);
                ['清淡', '咸香'].forEach(addIncludeTag);
            }
            if (hasSweetNegative) {
                ['甜', '甜品', '蛋糕', '冰淇淋'].forEach(addExcludeTag);
                ['咸香', '清淡', '主食'].forEach(addIncludeTag);
            }
            if (hasFriedNegative) {
                ['油炸', '炸鸡'].forEach(addExcludeTag);
                ['清淡', '蒸菜', '汤水'].forEach(addIncludeTag);
            }
            if (hasGreasyNegative) {
                ['油炸', '炸鸡', '重口', '辣'].forEach(addExcludeTag);
                ['清淡', '蒸菜', '汤水'].forEach(addIncludeTag);
            }
            if (hasRawColdNegative) {
                ['生冷', '冰品'].forEach(addExcludeTag);
                ['热饮', '汤水', '热食'].forEach(addIncludeTag);
            }
            if (hasSeafoodNegative) {
                ['海鲜', '鱼', '虾', '蟹'].forEach(addExcludeTag);
                ['鱼', '虾', '蟹', '海鲜', '生蚝', '鱿鱼', '寿司'].forEach(addExcludeKeyword);
            }
            if (hasMeatNegative) {
                ['肉食', '猪肉', '牛肉', '鸡肉', '羊肉', '牛肉饭'].forEach(addExcludeTag);
                ['肉', '牛', '羊', '猪', '鸡', '鸭', '排', '汉堡'].forEach(addExcludeKeyword);
            }
            if (hasBeefNegative) {
                ['牛肉', '牛肉饭'].forEach(addExcludeTag);
                ['牛', '牛排'].forEach(addExcludeKeyword);
            }
            if (hasChickenNegative) {
                ['鸡肉', '鸡汤', '炸鸡', '脆皮鸡'].forEach(addExcludeTag);
                ['鸡'].forEach(addExcludeKeyword);
            }
            if (hasPorkNegative) {
                ['猪肉'].forEach(addExcludeTag);
                ['猪', '猪脚', '猪肚', '红烧肉', '肉夹馍'].forEach(addExcludeKeyword);
            }
            if (hasLambNegative) {
                ['羊肉'].forEach(addExcludeTag);
                ['羊'].forEach(addExcludeKeyword);
            }

            // 遍历映射表匹配关键词
            Object.keys(FUZZY_SEARCH_MAP).forEach(keyword => {
                if (hasColdNegative && coldPositiveKeywords.includes(keyword)) return;
                if (hasSpicyNegative && spicyPositiveKeywords.includes(keyword)) return;
                if (hasSweetNegative && sweetPositiveKeywords.includes(keyword)) return;
                if (hasFriedNegative && friedPositiveKeywords.includes(keyword)) return;
                if (hasGreasyNegative && [...spicyPositiveKeywords, ...friedPositiveKeywords].includes(keyword)) return;
                if (hasSeafoodNegative && seafoodPositiveKeywords.includes(keyword)) return;
                if ((hasMeatNegative || hasBeefNegative || hasChickenNegative || hasPorkNegative || hasLambNegative) && meatPositiveKeywords.includes(keyword)) return;

                if (inputLower.includes(keyword)) {
                    const tags = FUZZY_SEARCH_MAP[keyword];
                    tags.forEach(tag => {
                        if (tag.startsWith('!')) {
                            // 排除标签
                            addExcludeTag(tag.substring(1));
                        } else {
                            // 包含标签
                            addIncludeTag(tag);
                        }
                    });
                }
            });

            return { includeTags, excludeTags, excludeKeywords };
        };

        const inferSearchTabId = (input, tags) => {
            const inputText = (input || '').toLowerCase().trim();
            if (!inputText || (!tags.includeTags.length && !tags.excludeTags.length)) return null;

            const hasTag = (candidates) => candidates.some(tag => tags.includeTags.includes(tag));
            const isNegativePreference = /(?:不要|不想|别|不)/.test(inputText) && tags.excludeTags.length > 0;

            if (isNegativePreference) {
                if (hasTag(['主食', '米饭', '面食', '粉类', '汤水', '汤面', '汤饭', '清淡', '咸香', '蒸菜', '热食'])) {
                    return 'meal';
                }
                return null;
            }

            if (/下午茶|甜|甜品|蛋糕|冰淇淋|点心|糕/.test(inputText) || hasTag(['甜品', '蛋糕', '冰淇淋', '烘焙', '糕点'])) {
                return 'dessert';
            }

            if (/喝|饮|奶茶|咖啡|果茶|热饮|豆浆|茶/.test(inputText) || hasTag(['饮品', '奶茶', '咖啡', '果茶', '热饮'])) {
                return 'drink';
            }

            if (/夜宵|宵夜|烧烤|烤串|串串|卤味|冷串/.test(inputText) || hasTag(['宵夜', '烧烤', '冷串', '卤味'])) {
                return 'night';
            }

            if (/饭|面|粉|汤|火锅|肉|鱼|海鲜|素|主食|正餐|快餐/.test(inputText) || hasTag(['正餐', '快餐', '面食', '粉类', '米饭', '主食', '汤水', '火锅'])) {
                return 'meal';
            }

            return null;
        };

        const getRandomBatch = (count, preferences, currentTab, sourceData, fuzzySearch = null) => {
            const hasFuzzySearch = fuzzySearch && (fuzzySearch.includeTags.length > 0 || fuzzySearch.excludeTags.length > 0 || (fuzzySearch.excludeKeywords && fuzzySearch.excludeKeywords.length > 0));
            let filteredPool = hasFuzzySearch ? [...sourceData] : sourceData.filter(item => {
                if (!currentTab.filterTags || currentTab.filterTags.length === 0) return true;
                return currentTab.filterTags.some(tag => item.tags.includes(tag));
            });

            // 模糊搜索过滤
            if (hasFuzzySearch) {
                filteredPool = filteredPool.filter(item => {
                    // 必须包含至少一个 includeTags（如果有的话）
                    if (fuzzySearch.includeTags.length > 0) {
                        const hasInclude = fuzzySearch.includeTags.some(tag => item.tags.includes(tag));
                        if (!hasInclude) return false;
                    }
                    // 不能包含任何 excludeTags
                    if (fuzzySearch.excludeTags.length > 0) {
                        const hasExclude = fuzzySearch.excludeTags.some(tag => item.tags.includes(tag));
                        if (hasExclude) return false;
                    }
                    if (fuzzySearch.excludeKeywords && fuzzySearch.excludeKeywords.length > 0) {
                        const searchableText = `${item.name} ${item.description || ''} ${item.tags.join(' ')}`;
                        const hasExcludedKeyword = fuzzySearch.excludeKeywords.some(keyword => searchableText.includes(keyword));
                        if (hasExcludedKeyword) return false;
                    }
                    return true;
                });
            }

            // Session Ban Logic (Filtered at selection time)
            if (preferences.sessionBannedIds && preferences.sessionBannedIds.length > 0) {
                filteredPool = filteredPool.filter(item => !preferences.sessionBannedIds.includes(item.id));
            }

            let pool = filteredPool.filter((item) => {
                if (preferences.excludedCategories.includes(item.category)) return false;
                if (item.tags.some(tag => preferences.excludedTags.includes(tag))) return false;
                return true;
            });

            if (pool.length === 0 && filteredPool.length > 0) pool = filteredPool;

            const weightedPool = [...pool];
            const favoriteIds = preferences.favoriteItemIds || [];
            const ignoredFavoriteIds = preferences.ignoredFavoriteIds || [];
            const shouldPrioritizeFavorites = preferences.prioritizeFavorites !== false;

            pool.forEach(item => {
                if (shouldPrioritizeFavorites && favoriteIds.includes(item.id) && !ignoredFavoriteIds.includes(item.id)) {
                    for (let i = 0; i < 5; i++) weightedPool.push(item);
                }
            });

            const shuffled = weightedPool.sort(() => 0.5 - Math.random());
            const selected = [];
            const selectedIds = new Set();
            for (const item of shuffled) {
                if (!selectedIds.has(item.id)) {
                    selected.push(item);
                    selectedIds.add(item.id);
                }
                if (selected.length >= count) break;
            }
            if (selected.length < count && pool.length > 0) {
                while (selected.length < count) {
                    selected.push(pool[Math.floor(Math.random() * pool.length)]);
                }
            }
            return selected.sort(() => 0.5 - Math.random());
        };

        // --- 3. COMPONENTS ---

        // 3.1 Wheel (High Contrast B&W)
        const Wheel = ({ items, isSpinning, onSpinComplete, winner, theme, isMuted }) => {
            const [currentRotation, setCurrentRotation] = useState(0);
            const [hoveredItem, setHoveredItem] = useState(null);
            
            const SIZE = 400; const CENTER = SIZE / 2; const RADIUS = SIZE / 2 - 10;
            const safeItems = items.length > 0 ? items : [{ id: 'empty', name: 'Loading', icon: '...', category: 'fast_food', tags: [] }];
            const itemCount = safeItems.length;
            const SLICE_ANGLE = 360 / itemCount;

            const isDark = theme === 'dark';

            const formatWheelLabel = (name) => {
                const text = (name || '').trim();
                const aliases = {
                    '兰州牛肉面': '牛肉面',
                    '黄焖鸡米饭': '黄焖鸡',
                    '隆江猪脚饭': '猪脚饭',
                    '潮汕牛肉火锅': '牛肉火锅',
                    '巴奴毛肚火锅': '毛肚火锅',
                    '捞王猪肚鸡': '猪肚鸡',
                    '西贝莜面村': '西贝',
                    '绿茶餐厅': '绿茶',
                    '奈雪的茶': '奈雪',
                    '蜜雪冰城': '蜜雪',
                    '茶颜悦色': '茶颜',
                    '霸王茶姬': '茶姬',
                    '书亦烧仙草': '书亦',
                    '一点点柠檬茶': '柠檬茶',
                    'DQ冰淇淋': 'DQ',
                    '墨茉点心局': '墨茉',
                    '幸福西饼': '西饼',
                    '糖水铺子': '糖水',
                    '杨枝甘露': '甘露',
                    '芋圆仙草': '芋圆',
                    '烧烤/烤串': '烤串',
                    'biangbiang面': 'biang面',
                    'Lady M': 'Lady',
                    'M Stand': 'M站',
                    'Seesaw': 'Seesaw',
                    '%Arabica': '%咖啡',
                    'CoCo都可': 'CoCo',
                };
                if (aliases[text]) return aliases[text];
                if (/^[A-Za-z0-9% .]+$/.test(text)) return text.length > 5 ? text.slice(0, 5) : text;
                const clean = text.replace(/[（）()·\s]/g, '');
                return clean.length > 4 ? clean.slice(0, 4) : clean;
            };

            useEffect(() => {
                if (isSpinning && winner) {
                    setHoveredItem(null);
                    const winnerIndex = safeItems.findIndex(i => i.id === winner.id);
                    const targetIndex = winnerIndex >= 0 ? winnerIndex : 0;
                    
                    const extraSpins = 360 * 6; 
                    const anglePerSlice = 360 / itemCount;
                    const randomOffset = (Math.random() - 0.5) * (anglePerSlice * 0.8);
                    const baseTargetRotation = 360 - (targetIndex * anglePerSlice) - (anglePerSlice / 2) + randomOffset;
                    
                    setCurrentRotation(prev => {
                        const currentMod = prev % 360;
                        let delta = baseTargetRotation - currentMod;
                        if (delta < 0) delta += 360;
                        return prev + delta + extraSpins;
                    });

                    // Audio Logic
                    if (!isMuted) {
                        AudioEngine.init();
                        AudioEngine.resume();
                        
                        const totalDuration = 4000;
                        const startTime = Date.now();
                        
                        const playTick = () => {
                            const elapsed = Date.now() - startTime;
                            const progress = elapsed / totalDuration; // 0 to 1
                            
                            if (progress < 1) {
                                // Calculate next tick based on speed (cubic ease-out derivative approx)
                                // Speed starts fast (low interval) and slows down (high interval)
                                const baseInterval = 50;
                                const slowFactor = 300;
                                const nextInterval = baseInterval + (Math.pow(progress, 3) * slowFactor);
                                
                                AudioEngine.playClick();
                                setTimeout(playTick, nextInterval);
                            } else {
                                AudioEngine.playWin();
                                onSpinComplete();
                            }
                        };
                        
                        // Start the loop
                        playTick();
                    } else {
                        setTimeout(() => onSpinComplete(), 4000);
                    }
                }
            }, [isSpinning, winner, safeItems, isMuted]); 

            const getCoordinatesForPercent = (percent) => [Math.cos(2 * Math.PI * percent), Math.sin(2 * Math.PI * percent)];

            return (
                <div className="relative flex flex-col items-center justify-center">
                    <div className="wheel-frame relative flex items-center justify-center">
                        <div className="absolute inset-[7%] rounded-full bg-white/10 dark:bg-white/5 blur-3xl pointer-events-none"></div>
                        {/* Outer Glow Ring (Visual Boost) */}
                        <div className={`absolute inset-[-8px] rounded-full blur-2xl opacity-25 ${isDark ? 'bg-white' : 'bg-black'} animate-pulse-slow`}></div>

                        {/* Pointer */}
                        <div className="wheel-pointer" aria-hidden="true">
                           <svg width="24" height="42" viewBox="0 0 24 42" fill="none">
                               <defs>
                                   <linearGradient id="pointerMetal" x1="3" y1="4" x2="21" y2="38" gradientUnits="userSpaceOnUse">
                                       <stop offset="0" stopColor={isDark ? '#FFFFFF' : '#FAFAFA'} />
                                       <stop offset="0.22" stopColor={isDark ? '#A1A1AA' : '#D4D4D8'} />
                                       <stop offset="0.48" stopColor={isDark ? '#F4F4F5' : '#FFFFFF'} />
                                       <stop offset="0.72" stopColor={isDark ? '#71717A' : '#A1A1AA'} />
                                       <stop offset="1" stopColor={isDark ? '#E4E4E7' : '#E5E7EB'} />
                                   </linearGradient>
                                   <linearGradient id="pointerEdge" x1="12" y1="3" x2="12" y2="39" gradientUnits="userSpaceOnUse">
                                       <stop offset="0" stopColor={isDark ? 'rgba(255,255,255,0.82)' : 'rgba(255,255,255,0.90)'} />
                                       <stop offset="1" stopColor={isDark ? 'rgba(0,0,0,0.58)' : 'rgba(24,24,27,0.48)'} />
                                   </linearGradient>
                               </defs>
                               <path d="M12 40L4.5 14L8.2 4H15.8L19.5 14L12 40Z" fill="url(#pointerMetal)" stroke="url(#pointerEdge)" strokeWidth="0.9" strokeLinejoin="miter"/>
                               <path d="M12 5.5V34" stroke={isDark ? 'rgba(255,255,255,0.68)' : 'rgba(255,255,255,0.86)'} strokeWidth="0.9"/>
                               <path d="M7.8 14H16.2" stroke={isDark ? 'rgba(0,0,0,0.40)' : 'rgba(24,24,27,0.28)'} strokeWidth="0.8"/>
                               <path d="M9.4 5.5L5.9 14L12 35.2" stroke={isDark ? 'rgba(255,255,255,0.20)' : 'rgba(255,255,255,0.46)'} strokeWidth="0.8"/>
                           </svg>
                        </div>
                        
                        {/* Wheel SVG */}
                        <div className="w-full h-full relative z-10" style={{ transform: `rotate(${currentRotation}deg)`, transition: isSpinning ? 'transform 4s cubic-bezier(0.2, 0, 0.1, 1)' : 'none' }}>
                            <svg viewBox={`0 0 ${SIZE} ${SIZE}`} className={`w-full h-full ${isDark ? 'drop-shadow-[0_0_20px_rgba(255,255,255,0.15)]' : 'drop-shadow-2xl'}`}>
                                <circle cx={CENTER} cy={CENTER} r={RADIUS} fill="#000000" />
                                {safeItems.map((item, index) => {
                                    const startPercent = (index / itemCount) - 0.25;
                                    const endPercent = ((index + 1) / itemCount) - 0.25;
                                    const [startX, startY] = getCoordinatesForPercent(startPercent);
                                    const [endX, endY] = getCoordinatesForPercent(endPercent);
                                    const pathData = [`M ${CENTER} ${CENTER}`, `L ${CENTER + RADIUS * startX} ${CENTER + RADIUS * startY}`, `A ${RADIUS} ${RADIUS} 0 ${1/itemCount > 0.5?1:0} 1 ${CENTER + RADIUS * endX} ${CENTER + RADIUS * endY}`, `Z`].join(' ');
                                    const isBlackSlice = index % 2 === 1;
                                    const angle = (index * SLICE_ANGLE) + (SLICE_ANGLE / 2) - 90;
                                    
                                    // High Contrast B&W Logic
                                    const sliceColor = isBlackSlice ? '#18181B' : '#FFFFFF';
                                    const textColor = isBlackSlice ? '#FFFFFF' : '#18181B';
                                    const strokeColor = isBlackSlice ? '#333333' : '#E5E5E5';
                                    const label = formatWheelLabel(item.name);
                                    const iconRadius = RADIUS * 0.67;
                                    const labelRadius = RADIUS * 0.50;

                                    return (
                                        <g key={index} onMouseEnter={() => !isSpinning && setHoveredItem(item)} onMouseLeave={() => !isSpinning && setHoveredItem(null)} onTouchStart={() => !isSpinning && setHoveredItem(item)}>
                                            <path d={pathData} fill={sliceColor} stroke={strokeColor} strokeWidth="1"/>
                                            <g transform={`translate(${CENTER + iconRadius * Math.cos(angle * Math.PI / 180)}, ${CENTER + iconRadius * Math.sin(angle * Math.PI / 180)}) rotate(${angle + 90})`}>
                                                <text textAnchor="middle" fontSize="46" dy="3">{item.icon}</text>
                                            </g>
                                            <g transform={`translate(${CENTER + labelRadius * Math.cos(angle * Math.PI / 180)}, ${CENTER + labelRadius * Math.sin(angle * Math.PI / 180)}) rotate(${angle + 90})`}>
                                                <text textAnchor="middle" fill={textColor} fontSize={label.length > 4 ? "13" : "14"} fontWeight="850" dy="4">{label}</text>
                                            </g>
                                        </g>
                                    );
                                })}
                            </svg>
                        </div>
                        {/* Center Cat */}
                        <div className="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[12%] h-[12%] z-20 flex items-center justify-center pointer-events-none">
                            {USER_CAT_IMAGE_SRC ? (
                                <img src={USER_CAT_IMAGE_SRC} className="w-full h-full object-contain sticker-effect" alt="Cat" />
                            ) : (
                                <img src={DEFAULT_CAT_IMAGE} className="w-full h-full object-contain sticker-effect" alt="Cat" />
                            )}
                        </div>
                    </div>
                     <div className="absolute bottom-[18px] left-1/2 -translate-x-1/2 z-20 pointer-events-none transition-all duration-300 w-full flex justify-center px-8">
                        <div className={`ios-glass px-4 py-2.5 rounded-2xl w-auto max-w-[260px] text-center transition-opacity duration-300 ${hoveredItem ? 'opacity-100' : 'opacity-0'} ${isDark ? 'text-zinc-100' : 'text-zinc-900'}`}>
                            <div className="text-[12px] font-medium leading-tight">{hoveredItem?.description || '...'}</div>
                        </div>
                    </div>
                </div>
            );
        };

        // 3.2 Result Card (Enhanced Poster + Live Preview)
        const ResultCard = ({ winner, onClose, onRetry, isFavorite, onToggleFavorite, theme, onBanSession }) => {
            const [isGenerating, setIsGenerating] = useState(false);
            const [posterTheme, setPosterTheme] = useState('white'); // white, black, red
            
            if (!winner) return null;

            const getDisplayLabel = (item) => {
                if (item.tags.includes('宵夜')) return '宵夜';
                if (item.tags.includes('甜品')) return '甜品';
                if (item.tags.includes('饮品')) return '饮品';
                if (item.tags.includes('早餐')) return '早餐';
                return CATEGORY_LABELS[item.category] || '美食';
            };

            const displayLabel = getDisplayLabel(winner);

            const copyName = () => {
                navigator.clipboard.writeText(winner.name);
                alert(`已复制: ${winner.name}`);
            }

            const posterThemeLabels = {
                white: '极简白',
                black: '暗夜黑',
                red: '锦鲤红'
            };

            const escapeHtml = (value) => String(value || '').replace(/[&<>"']/g, (char) => ({
                '&': '&amp;',
                '<': '&lt;',
                '>': '&gt;',
                '"': '&quot;',
                "'": '&#39;'
            }[char]));

            const handleShare = async () => {
                if (isGenerating) return;
                setIsGenerating(true);
                
                const downloadPoster = (canvas) => {
                    const a = document.createElement('a');
                    a.href = canvas.toDataURL('image/png');
                    a.download = `选了么-${winner.name}.png`;
                    a.click();
                };

                // Generate High-Res Poster for Export
                const poster = document.createElement('div');
                
                // Theme logic for export (same as preview)
                let bg = 'white'; let text = 'black'; let border = '#e5e5e5';
                if (posterTheme === 'black') { bg = '#09090b'; text = 'white'; border = '#27272a'; }
                if (posterTheme === 'red') { bg = 'linear-gradient(135deg, #ef4444 0%, #b91c1c 100%)'; text = '#fffbeb'; border = '#fecaca'; }

                const texture = `background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.05'/%3E%3C/svg%3E");`;

                poster.style.cssText = `position:fixed;top:0;left:0;width:375px;height:600px;padding:36px 22px;text-align:center;z-index:-1;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;display:flex;flex-direction:column;justify-content:space-between;background:${bg};color:${text};box-sizing:border-box;`;
                
                poster.innerHTML = `
                    <div style="position:absolute;inset:0;${texture}pointer-events:none;"></div>
                    <div style="position:relative;z-index:1;">
                        <div style="font-size:11px;opacity:0.58;letter-spacing:3px;text-align:center;text-transform:uppercase;">Today's Choice</div>
                        <div style="font-size:96px;margin:24px auto 18px auto;text-align:center;display:block;filter:drop-shadow(0 10px 20px rgba(0,0,0,0.18));">${escapeHtml(winner.icon)}</div>
                        <h1 style="font-size:42px;font-weight:900;margin:0;color:${text};text-align:center;line-height:1.08;letter-spacing:0;">${escapeHtml(winner.name)}</h1>
                        <div style="font-size:13px;font-weight:800;opacity:0.78;margin:24px auto 0 auto;border-top:1px solid ${border};border-bottom:1px solid ${border};padding:8px 0;width:100%;letter-spacing:2px;">
                            ${escapeHtml(displayLabel)}
                        </div>
                        <p style="font-size:15px;opacity:0.88;margin:28px auto 0 auto;max-width:86%;line-height:1.72;text-align:center;font-weight:500;">${escapeHtml(winner.description)}</p>
                    </div>
                    <div style="position:relative;z-index:1;border-top:1px solid ${border};padding-top:20px;font-size:10px;opacity:0.5;text-align:center;letter-spacing:1px;">选了么 · 今天吃什么</div>
                `;
                
                document.body.appendChild(poster);
                
                try {
                    const canvas = await html2canvas(poster, { scale: 2, useCORS: true, allowTaint: true, backgroundColor: bg.includes('gradient') ? '#ef4444' : bg });
                    document.body.removeChild(poster);
                    const blob = await new Promise(r => canvas.toBlob(r));
                    const file = new File([blob], "share.png", { type: "image/png" });

                    if (navigator.canShare && navigator.canShare({ files: [file] })) {
                        try {
                            await navigator.share({ files: [file] });
                        } catch (shareError) {
                            console.warn('系统分享不可用，已改为下载海报:', shareError);
                            downloadPoster(canvas);
                        }
                    } else {
                        downloadPoster(canvas);
                    }
                } catch (e) {
                    console.error('海报生成失败:', e);
                    alert('海报生成失败，请稍后重试');
                    if(document.body.contains(poster)) document.body.removeChild(poster);
                }
                setIsGenerating(false);
            };

            return (
                <div className="fixed inset-0 z-50 flex items-center justify-center p-3 bg-black/72 backdrop-blur-xl animate-in fade-in" onClick={(e) => {e.stopPropagation(); onClose();}}>
                    <div className="result-panel ios-glass w-full max-w-sm rounded-[28px] p-5 text-center relative text-zinc-950 dark:text-white" onClick={e=>e.stopPropagation()}>
                        
                        <button onClick={onClose} className="absolute top-3 right-3 ios-glass-soft ios-icon-button p-2 rounded-full hover:scale-105 active:scale-95 transition-transform" aria-label="关闭">
                            <Icons.X className="w-4 h-4"/>
                        </button>

                        <div className="text-[11px] font-black tracking-[0.28em] mb-3 text-zinc-500 dark:text-zinc-400">决定了，就是它</div>
                        
                        <div className="relative inline-block" onClick={copyName} title="点击复制">
                             {isFavorite && <div className="absolute -top-2 -right-2 bg-yellow-400 p-1.5 rounded-full shadow-lg"><Icons.Star className="w-4 h-4 text-white fill-white"/></div>}
                             <div className="result-icon text-[76px] mb-2 drop-shadow-2xl active:scale-95 transition-transform leading-none">{winner.icon}</div>
                        </div>
                        
                        <h2 className="result-title text-[32px] font-black mb-2 flex items-center justify-center gap-2 leading-tight" onClick={copyName}>{winner.name}</h2>
                        
                        <div className="mb-4 flex justify-center w-full mt-3">
                             <span className="text-xs font-black w-full py-2 border-t border-b border-zinc-950/10 dark:border-white/15 text-zinc-500 dark:text-zinc-400 tracking-[0.16em]">{displayLabel}</span>
                        </div>

                        <p className="result-description text-sm mb-5 px-2 leading-relaxed font-medium min-h-[2.6rem] text-zinc-600 dark:text-zinc-300">{winner.description}</p>
                        
                        <div className={`poster-preview poster-preview-${posterTheme} mb-4 px-4 py-3 text-left`}>
                            <div className="flex items-center justify-between gap-3">
                                <div>
                                    <div className="text-[10px] font-black tracking-[0.2em] opacity-60">海报预览</div>
                                    <div className="text-sm font-black mt-1">{posterThemeLabels[posterTheme]}</div>
                                </div>
                                <div className="text-3xl leading-none">{winner.icon}</div>
                            </div>
                            <div className="mt-2 text-xs opacity-70 truncate">{winner.name} · {displayLabel}</div>
                        </div>

                        <div className="mb-4 flex items-center justify-center gap-3">
                            <span className="text-[10px] font-bold tracking-[0.18em] text-zinc-500 dark:text-zinc-400">样式</span>
                            <div className="flex justify-center gap-3" aria-label="海报主题">
                                <button onClick={() => setPosterTheme('white')} aria-pressed={posterTheme === 'white'} className="result-theme-dot bg-white" title="极简白" aria-label="极简白"></button>
                                <button onClick={() => setPosterTheme('black')} aria-pressed={posterTheme === 'black'} className="result-theme-dot bg-zinc-950" title="暗夜黑" aria-label="暗夜黑"></button>
                                <button onClick={() => setPosterTheme('red')} aria-pressed={posterTheme === 'red'} className="result-theme-dot bg-gradient-to-br from-red-500 to-red-700" title="锦鲤红" aria-label="锦鲤红"></button>
                            </div>
                        </div>

                        <div className="grid grid-cols-2 gap-3 mb-3">
                            <button 
                                onClick={handleShare} 
                                disabled={isGenerating} 
                                className="py-3 rounded-2xl font-black flex items-center justify-center gap-2 transition-all shadow-lg hover:scale-[1.01] active:scale-[0.98] bg-zinc-950 dark:bg-white text-white dark:text-black disabled:opacity-50"
                            >
                                <Icons.Share2 className="w-4 h-4"/> {isGenerating ? '生成中' : '分享'}
                            </button>
                            
                            <button 
                                onClick={onRetry} 
                                className="py-3 rounded-2xl font-black flex items-center justify-center gap-2 transition-all ios-glass-soft hover:scale-[1.01] active:scale-[0.98]"
                            >
                                <Icons.RefreshCw className="w-4 h-4"/> 重选
                            </button>
                        </div>
                        
                        <button onClick={onBanSession} className="w-full py-2 mb-3 text-xs text-zinc-500 dark:text-zinc-400 hover:text-red-500 dark:hover:text-red-300 flex items-center justify-center gap-1 transition-colors">
                            <Icons.Ban className="w-3 h-3"/> 今天先不吃这个
                        </button>

                        <div className="flex justify-center">
                            <button onClick={onToggleFavorite} className={`text-xs font-bold flex items-center gap-1 transition-colors ${isFavorite ? 'text-yellow-400' : 'opacity-40 hover:opacity-100'}`}><Icons.Star className={`w-3 h-3 ${isFavorite?'fill-yellow-400':''}`}/> {isFavorite?'已收藏':'收藏'}</button>
                        </div>
                    </div>
                </div>
            );
        };

        // 3.3 Add Food Modal
        const AddFoodModal = ({ isOpen, onClose, onAdd, initialItem, navTabs }) => {
            const [name, setName] = useState('');
            const [icon, setIcon] = useState('😋');
            const [category, setCategory] = useState('chinese');
            const [tags, setTags] = useState('');
            const [description, setDescription] = useState('');

            useEffect(() => {
                if (isOpen && initialItem) {
                    setName(initialItem.name);
                    setIcon(initialItem.icon);
                    setCategory(initialItem.category);
                    setTags(initialItem.tags.join(', '));
                    setDescription(initialItem.description || '');
                } else if (isOpen) {
                    setName(''); setIcon('😋'); setCategory('chinese'); setTags(''); setDescription('');
                }
            }, [isOpen, initialItem]);

            const handleSubmit = (e) => {
                e.preventDefault();
                const newItem = {
                    id: initialItem ? initialItem.id : `custom_${Date.now()}`,
                    name: name.trim(), icon: icon.trim() || '🥘', category,
                    tags: tags.split(/[,，\s]+/).filter(t => t.trim()),
                    description: description.trim()
                };
                onAdd(newItem); onClose();
            };

            if (!isOpen) return null;
            return (
                <div className="fixed inset-0 z-[60] flex items-center justify-center p-3 modal-backdrop" onClick={onClose}>
                    <div className="modal-panel modal-scroll ios-glass w-full max-w-md p-5 text-zinc-950 dark:text-white" onClick={e=>e.stopPropagation()}>
                        <div className="flex items-center justify-between mb-4"><h2 className="modal-title">{initialItem?'编辑':'添加'}美食</h2><button onClick={onClose} className="modal-close ios-glass-soft ios-icon-button"><Icons.X className="w-4 h-4"/></button></div>
                        <form onSubmit={handleSubmit} className="space-y-4">
                            <input value={name} onChange={e=>setName(e.target.value)} placeholder="名称" className="modal-field p-3" required/>
                            <div className="flex gap-2">
                                <input value={icon} onChange={e=>setIcon(e.target.value)} className="modal-field w-16 p-3 text-center" />
                                <select value={category} onChange={e=>setCategory(e.target.value)} className="modal-field flex-1 p-3">
                                    {Object.entries(CATEGORY_LABELS).map(([k,v])=><option key={k} value={k}>{v}</option>)}
                                </select>
                            </div>
                            <div>
                                <label className="text-[10px] text-zinc-500 mb-1 block">推荐标签顺序: 类型, 地域, 口味</label>
                                <input value={tags} onChange={e=>setTags(e.target.value)} placeholder="标签 (逗号分隔)" className="modal-field p-3 mb-2"/>
                                <div className="flex flex-wrap gap-1">{navTabs.map(t=>t.filterTags.map(tag=><button type="button" key={tag} onClick={()=>setTags(prev=>prev?prev+', '+tag:tag)} className="text-[10px] modal-tile px-2 py-1 rounded-lg hover:opacity-80">{tag}</button>))}</div>
                                <div className="mt-2 text-[10px] text-zinc-600 dark:text-zinc-400">
                                    预览: {tags.split(/[,，\s]+/).filter(t=>t).map((t,i)=><span key={i} className={`mr-1 px-1 rounded ${i===0?'bg-zinc-200 dark:bg-zinc-700':i===1?'bg-zinc-100 dark:bg-zinc-800':'bg-gray-50 dark:bg-zinc-900'}`}>{t}</span>)}
                                </div>
                            </div>
                            <textarea value={description} onChange={e=>setDescription(e.target.value)} placeholder="简介" className="modal-field p-3" rows={2}/>
                            <button type="submit" className="modal-primary w-full py-3">保存</button>
                        </form>
                    </div>
                </div>
            );
        };

        // 3.4 Category Manager
        const CategoryManager = ({ isOpen, onClose, tabs, onUpdateTabs }) => {
            const [editingTab, setEditingTab] = useState(null);
            const [localTagInput, setLocalTagInput] = useState('');

            if (!isOpen) return null;
            
            const handleSave = () => {
                if(!editingTab.label) return;
                const tagsArray = localTagInput.split(/[,，\s]+/).filter(t=>t);
                const newTab = { ...editingTab, filterTags: tagsArray };
                delete newTab.isNew; 
                const newTabs = editingTab.isNew ? [...tabs, {...newTab, id: `tab_${Date.now()}`}] : tabs.map(t=>t.id===newTab.id?newTab:t);
                onUpdateTabs(newTabs); 
                setEditingTab(null);
                setLocalTagInput('');
            };

            const startEdit = (tab) => {
                setEditingTab({...tab});
                setLocalTagInput(tab.filterTags ? tab.filterTags.join(', ') : '');
            }

            const startAdd = () => {
                setEditingTab({ id: `tab_${Date.now()}`, label: '', iconName: 'Layers', filterTags: [], isSystem: false, isNew: true });
                setLocalTagInput('');
            }

            return (
                <div className="fixed inset-0 z-[60] flex items-center justify-center p-3 modal-backdrop" onClick={onClose}>
                    <div className="modal-panel modal-scroll ios-glass w-full max-w-md p-5 text-zinc-950 dark:text-white" onClick={e=>e.stopPropagation()}>
                        <div className="flex items-center justify-between mb-4"><h2 className="modal-title">分类管理</h2><button onClick={onClose} className="modal-close ios-glass-soft ios-icon-button"><Icons.X className="w-4 h-4"/></button></div>
                        {editingTab ? (
                            <div className="space-y-3">
                                <input value={editingTab.label} onChange={e=>setEditingTab({...editingTab, label:e.target.value})} placeholder="分类名称" className="modal-field p-3"/>
                                <input value={localTagInput} onChange={e=>setLocalTagInput(e.target.value)} placeholder="筛选标签 (逗号分隔)" className="modal-field p-3"/>
                                <div className="flex gap-2"><button onClick={handleSave} className="modal-primary flex-1 py-2.5">保存</button><button onClick={() => setEditingTab(null)} className="modal-secondary ios-glass-soft flex-1 py-2.5">取消</button></div>
                            </div>
                        ) : (
                            <div className="space-y-2">
                                {tabs.map(t=>(
                                    <div key={t.id} className="modal-tile flex justify-between p-3 rounded-2xl items-center">
                                        <span>{t.label}</span>
                                        <div className="flex gap-2">
                                            <button onClick={()=>startEdit(t)}><Icons.Edit className="w-4 h-4 text-zinc-400"/></button>
                                            <button onClick={()=>onUpdateTabs(tabs.filter(x=>x.id!==t.id))}><Icons.Trash2 className="w-4 h-4 text-red-400"/></button>
                                        </div>
                                    </div>
                                ))}
                                <button onClick={startAdd} className="modal-secondary ios-glass-soft w-full py-3 text-zinc-700 dark:text-zinc-200 flex justify-center items-center gap-2"><Icons.Plus className="w-4 h-4"/> 添加分类</button>
                            </div>
                        )}
                    </div>
                </div>
            );
        };

        // 3.5 Settings
        const Settings = ({ isOpen, onClose, prefs, updatePrefs, allFoodItems, theme, toggleTheme, isMuted, toggleMute }) => {
            const fileInputRef = useRef(null);
            if (!isOpen) return null;
            
            const toggle = (arr, val) => arr.includes(val) ? arr.filter(x=>x!==val) : [...arr, val];
            const handleExport = () => {
                const data = JSON.stringify({prefs, date: new Date().toISOString()});
                const blob = new Blob([data], {type: 'application/json'});
                const url = URL.createObjectURL(blob);
                const a = document.createElement('a'); a.href = url; a.download = 'eat_backup.json'; a.click();
            };
            const handleImport = (e) => {
                const file = e.target.files[0];
                if(file) {
                    const reader = new FileReader();
                    reader.onload = (ev) => { try { const p = JSON.parse(ev.target.result); if(p.prefs) updatePrefs(normalizePrefs(p.prefs)); alert('恢复成功'); window.location.reload(); } catch(err){alert('文件错误');} };
                    reader.readAsText(file);
                }
            };

            const toggleFavoriteActive = (id) => {
                const ignored = prefs.ignoredFavoriteIds || [];
                const newIgnored = ignored.includes(id) ? ignored.filter(i => i !== id) : [...ignored, id];
                updatePrefs({...prefs, ignoredFavoriteIds: newIgnored});
            };

            return (
                <div className="fixed inset-0 z-50 flex items-center justify-center p-3 modal-backdrop" onClick={onClose}>
                    <div className="modal-panel ios-glass w-full max-w-md h-[min(85svh,620px)] p-5 flex flex-col text-zinc-950 dark:text-white" onClick={e=>e.stopPropagation()}>
                        <div className="flex items-center justify-between mb-4"><h2 className="modal-title">偏好设置</h2><button onClick={onClose} className="modal-close ios-glass-soft ios-icon-button"><Icons.X className="w-4 h-4"/></button></div>
                        <div className="flex-1 modal-scroll space-y-5 pr-1">
                             
                             {/* Theme & Sound Toggle */}
                             <section className="grid grid-cols-2 gap-3">
                                <div className="modal-tile flex items-center justify-between p-3 rounded-2xl">
                                    <div className="flex items-center gap-2 text-xs font-bold">
                                        {theme === 'dark' ? <Icons.Moon className="w-4 h-4"/> : <Icons.Sun className="w-4 h-4"/>} 模式
                                    </div>
                                    <button onClick={toggleTheme} className="ios-glass-soft px-3 py-1.5 rounded-full text-xs font-bold transition-all">切换</button>
                                </div>
                                <div className="modal-tile flex items-center justify-between p-3 rounded-2xl">
                                    <div className="flex items-center gap-2 text-xs font-bold">
                                        {isMuted ? <Icons.VolumeX className="w-4 h-4"/> : <Icons.Volume2 className="w-4 h-4"/>} 音效
                                    </div>
                                    <button onClick={toggleMute} className={`px-3 py-1.5 rounded-full text-xs font-bold transition-all ${isMuted ? 'ios-glass-soft text-zinc-500' : 'bg-white text-zinc-950 shadow-sm'}`}>{isMuted ? '关' : '开'}</button>
                                </div>
                             </section>

                             <section>
                                <div className="flex items-center justify-between mb-3">
                                    <h3 className="text-xs font-bold text-zinc-500 uppercase">优先推荐收藏</h3>
                                    <button onClick={() => updatePrefs({...prefs, prioritizeFavorites: !prefs.prioritizeFavorites})} className={`flex items-center gap-2 ${prefs.prioritizeFavorites ? "text-yellow-500" : "text-zinc-400"}`}>
                                        {prefs.prioritizeFavorites ? <Icons.ToggleRight className="w-8 h-8"/> : <Icons.ToggleLeft className="w-8 h-8"/>}
                                    </button>
                                </div>
                                {prefs.prioritizeFavorites && (
                                    <div className="flex flex-wrap gap-2">
                                        {(prefs.favoriteItemIds||[]).map(id => {
                                            const item = allFoodItems.find(i=>i.id===id);
                                            if(!item) return null;
                                            const isActive = !(prefs.ignoredFavoriteIds||[]).includes(id);
                                            return (
                                                <button key={id} onClick={() => toggleFavoriteActive(id)} className={`px-2 py-1 rounded-lg text-xs border ${isActive ? 'bg-yellow-100 dark:bg-yellow-900/30 border-yellow-300 dark:border-yellow-700 text-yellow-700 dark:text-yellow-200' : 'bg-gray-100 dark:bg-zinc-800 border-gray-200 dark:border-zinc-700 text-zinc-400 line-through'}`}>
                                                    {item.name}
                                                </button>
                                            )
                                        })}
                                    </div>
                                )}
                            </section>
                            <section>
                                <h3 className="text-xs font-bold text-zinc-500 mb-2 uppercase">口味屏蔽</h3>
                                <div className="grid grid-cols-4 gap-2">{FLAVOR_OPTIONS.map(f=><button key={f} onClick={()=>updatePrefs({...prefs, excludedTags:toggle(prefs.excludedTags,f)})} className={`py-2 rounded-xl text-xs border transition-all ${prefs.excludedTags.includes(f)?'bg-red-50/90 dark:bg-red-900/30 border-red-200 dark:border-red-800 text-red-500 dark:text-red-300 line-through':'modal-tile text-zinc-700 dark:text-zinc-200'}`}>{f}</button>)}</div>
                            </section>
                            <section>
                                <h3 className="text-xs font-bold text-zinc-500 mb-2 uppercase">菜系屏蔽</h3>
                                <div className="grid grid-cols-4 gap-2">{GEO_OPTIONS.map(g=><button key={g} onClick={()=>updatePrefs({...prefs, excludedTags:toggle(prefs.excludedTags,g)})} className={`py-2 rounded-xl text-xs border transition-all ${prefs.excludedTags.includes(g)?'bg-red-50/90 dark:bg-red-900/30 border-red-200 dark:border-red-800 text-red-500 dark:text-red-300 line-through':'modal-tile text-zinc-700 dark:text-zinc-200'}`}>{g}</button>)}</div>
                            </section>
                            <section className="modal-tile p-4 rounded-2xl">
                                <h3 className="text-xs font-bold text-zinc-500 mb-2 uppercase">数据备份</h3>
                                <div className="flex gap-2">
                                    <button onClick={handleExport} className="modal-secondary ios-glass-soft flex-1 py-2 text-xs"><Icons.Download className="w-3 h-3 inline mr-1"/> 导出</button>
                                    <button onClick={()=>fileInputRef.current.click()} className="modal-secondary ios-glass-soft flex-1 py-2 text-xs"><Icons.Upload className="w-3 h-3 inline mr-1"/> 导入</button>
                                    <input type="file" ref={fileInputRef} hidden onChange={handleImport} accept=".json"/>
                                </div>
                            </section>
                        </div>
                    </div>
                </div>
            );
        };

        // 3.6 Food Details Modal
        const FoodDetailModal = ({ isOpen, onClose, item, onEdit, isFav, onToggleFav }) => {
            if(!isOpen || !item) return null;
            return (
                <div className="fixed inset-0 z-[55] flex items-center justify-center p-3 modal-backdrop animate-in fade-in" onClick={onClose}>
                    <div className="modal-panel modal-scroll ios-glass w-full max-w-sm p-5 text-center relative text-zinc-950 dark:text-white" onClick={e=>e.stopPropagation()}>
                        <button onClick={onEdit} className="absolute top-3 right-3 modal-close ios-glass-soft ios-icon-button"><Icons.Edit2 className="w-4 h-4"/></button>
                        <div className="text-[76px] leading-none mb-4">{item.icon}</div>
                        <h2 className="text-[30px] font-black mb-2 leading-tight">{item.name}</h2>
                        <div className="flex flex-wrap gap-2 justify-center mb-6">
                            {item.tags.map(t=>(
                                <span key={t} className="modal-tile px-2 py-1 rounded-lg text-xs text-zinc-500 dark:text-zinc-300">{t}</span>
                            ))}
                        </div>
                        <p className="text-sm text-zinc-500 mb-8 leading-relaxed">{item.description}</p>
                        <button onClick={onToggleFav} className={`w-full py-3 rounded-2xl font-bold border flex items-center justify-center gap-2 ${isFav?'bg-yellow-50/90 dark:bg-yellow-900/20 border-yellow-200 dark:border-yellow-700 text-yellow-600 dark:text-yellow-400':'ios-glass-soft text-zinc-500 dark:text-zinc-300'}`}>
                            <Icons.Star className={`w-4 h-4 ${isFav?'fill-yellow-500':''}`}/> {isFav?'已收藏':'加入收藏'}
                        </button>
                    </div>
                </div>
            )
        }

        // 3.7 Food Library
        const FoodLibrary = ({ isOpen, onClose, items, onEdit, favs, onToggleFav, navTabs }) => {
            const [search, setSearch] = useState('');
            const [activeTabId, setActiveTabId] = useState('all');
            const [showFavsOnly, setShowFavsOnly] = useState(false);
            const [viewingItem, setViewingItem] = useState(null);

            if(!isOpen) return null;
            
            const getDisplayLabel = (item) => {
                if (item.tags.includes('宵夜')) return '宵夜';
                if (item.tags.includes('甜品')) return '甜品';
                if (item.tags.includes('饮品')) return '饮品';
                if (item.tags.includes('早餐')) return '早餐';
                return CATEGORY_LABELS[item.category];
            };

            const filtered = items.filter(item => {
                if (showFavsOnly && !favs.includes(item.id)) return false;
                if (search && !item.name.includes(search) && !item.tags.some(t=>t.includes(search))) return false;
                if (activeTabId !== 'all') {
                    const tab = navTabs.find(t=>t.id===activeTabId);
                    if (tab && tab.filterTags.length > 0 && !tab.filterTags.some(tag=>item.tags.includes(tag))) return false;
                }
                return true;
            });

            return (
                <>
                <div className="fixed inset-0 z-50 flex items-center justify-center p-3 modal-backdrop" onClick={onClose}>
                    <div className="modal-panel ios-glass w-full max-w-2xl h-[min(85svh,640px)] flex flex-col text-zinc-950 dark:text-white" onClick={e=>e.stopPropagation()}>
                        <div className="p-4 flex items-center justify-between"><h2 className="modal-title">美食图鉴</h2><button onClick={onClose} className="modal-close ios-glass-soft ios-icon-button"><Icons.X className="w-4 h-4"/></button></div>
                        <div className="px-4 pb-4 space-y-3">
                             <div className="flex gap-2">
                                <div className="relative flex-1"><Icons.Search className="absolute left-3 top-2.5 w-4 h-4 text-zinc-500"/><input value={search} onChange={e=>setSearch(e.target.value)} placeholder="搜索..." className="modal-field pl-9 p-2"/></div>
                                <button onClick={()=>setShowFavsOnly(!showFavsOnly)} className={`p-2 rounded-2xl border ${showFavsOnly?'bg-yellow-50/90 dark:bg-yellow-900/30 border-yellow-200 dark:border-yellow-700 text-yellow-500':'ios-glass-soft text-zinc-400'}`}><Icons.Star className={`w-5 h-5 ${showFavsOnly?'fill-yellow-500':''}`}/></button>
                             </div>
                             <div className="flex gap-2 overflow-x-auto nav-scrollbar pb-1">
                                {navTabs.map(t=>(<button key={t.id} onClick={()=>setActiveTabId(t.id)} className={`px-3 py-1.5 rounded-full text-xs border shrink-0 ${activeTabId===t.id?'bg-black dark:bg-white text-white dark:text-black border-black dark:border-white':'modal-tile text-zinc-600 dark:text-zinc-300'}`}>{t.label}</button>))}
                             </div>
                        </div>
                        <div className="flex-1 modal-scroll px-4 pb-4 grid grid-cols-3 gap-3 content-start">
                            {filtered.map(item=>(
                                <div key={item.id} className="modal-tile p-3 rounded-2xl text-center relative group aspect-square flex flex-col items-center justify-center hover:opacity-90 transition-opacity" onClick={()=>setViewingItem(item)}>
                                    <div className="absolute top-1 right-1"><Icons.Star className={`w-3 h-3 ${favs.includes(item.id)?'fill-yellow-500 text-yellow-500':'text-gray-300 dark:text-zinc-800'}`}/></div>
                                    <div className="text-3xl mb-1">{item.icon}</div>
                                    <div className="text-xs font-bold truncate w-full px-1">{item.name}</div>
                                    <div className="text-[10px] text-zinc-500 mt-1">{getDisplayLabel(item)}</div>
                                </div>
                            ))}
                        </div>
                    </div>
                </div>
                <FoodDetailModal 
                    isOpen={!!viewingItem} 
                    item={viewingItem} 
                    onClose={()=>setViewingItem(null)} 
                    onEdit={()=>{setViewingItem(null); onEdit(viewingItem)}}
                    isFav={viewingItem && favs.includes(viewingItem.id)}
                    onToggleFav={()=>onToggleFav(viewingItem.id)}
                />
                </>
            );
        };

        // 3.8 History
        const History = ({ isOpen, onClose, history, onClear }) => {
            if(!isOpen) return null;
            return (
                <div className="fixed inset-0 z-50 flex items-center justify-center p-3 modal-backdrop" onClick={onClose}>
                    <div className="modal-panel ios-glass w-full max-w-sm h-[min(70svh,520px)] p-5 flex flex-col text-zinc-950 dark:text-white" onClick={e=>e.stopPropagation()}>
                        <div className="flex items-center justify-between mb-4"><h2 className="modal-title">历史记录</h2><button onClick={onClose} className="modal-close ios-glass-soft ios-icon-button"><Icons.X className="w-4 h-4"/></button></div>
                        <div className="flex-1 modal-scroll space-y-2">
                            {history.length === 0 && (
                                <div className="h-full min-h-[180px] flex flex-col items-center justify-center text-center text-zinc-500 dark:text-zinc-400">
                                    <Icons.History className="w-8 h-8 mb-3 opacity-50"/>
                                    <div className="text-sm font-bold">还没有记录</div>
                                    <div className="text-xs mt-1">转一次就会出现在这里</div>
                                </div>
                            )}
                            {history.slice().reverse().map((h,i)=>(
                                <div key={i} className="modal-tile flex items-center gap-3 p-2.5 rounded-2xl">
                                    <span className="text-xl">{h.food.icon}</span>
                                    <div><div className="text-sm font-bold">{h.food.name}</div><div className="text-[10px] text-zinc-500">{new Date(h.timestamp).toLocaleString('zh-CN', { month: 'numeric', day: 'numeric', hour: '2-digit', minute: '2-digit' })}</div></div>
                                </div>
                            ))}
                        </div>
                        {history.length>0 && <button onClick={onClear} className="mt-3 text-xs text-red-500 hover:text-red-400 text-center w-full py-2">清空历史</button>}
                    </div>
                </div>
            );
        };

        // --- 4. MAIN APP ---
        const DEFAULT_PREFS = {
            excludedCategories: [],
            excludedTags: [],
            favoriteItemIds: [],
            prioritizeFavorites: true,
            ignoredFavoriteIds: [],
            sessionBannedIds: []
        };

        const normalizePrefs = (prefs = {}) => ({
            ...DEFAULT_PREFS,
            ...prefs,
            excludedCategories: Array.isArray(prefs.excludedCategories) ? prefs.excludedCategories : [],
            excludedTags: Array.isArray(prefs.excludedTags) ? prefs.excludedTags : [],
            favoriteItemIds: Array.isArray(prefs.favoriteItemIds) ? prefs.favoriteItemIds : [],
            ignoredFavoriteIds: Array.isArray(prefs.ignoredFavoriteIds) ? prefs.ignoredFavoriteIds : [],
            sessionBannedIds: Array.isArray(prefs.sessionBannedIds) ? prefs.sessionBannedIds : []
        });

        const App = () => {
            const [items, setItems] = useState([]);
            const [isSpinning, setIsSpinning] = useState(false);
            const [winner, setWinner] = useState(null);
            const [navTabs, setNavTabs] = useState(DEFAULT_NAV_TABS);
            const [activeTabId, setActiveTabId] = useState('all');
            const [prefs, setPrefs] = useState(DEFAULT_PREFS);
            const [history, setHistory] = useState([]);
            const [customItems, setCustomItems] = useState([]);
            const [foodOverrides, setFoodOverrides] = useState({});
            const [theme, setTheme] = useState('dark');
            const [isMuted, setIsMuted] = useState(false);
            const [greeting, setGreeting] = useState('今天吃什么');
            const [fuzzySearchInput, setFuzzySearchInput] = useState('');
            const [fuzzySearchTags, setFuzzySearchTags] = useState({ includeTags: [], excludeTags: [], excludeKeywords: [] });
            const [showTopMenu, setShowTopMenu] = useState(false);

            // Modals
            const [modals, setModals] = useState({ settings: false, history: false, add: false, library: false, catManager: false });
            const [editingItem, setEditingItem] = useState(null);

            // Drag to scroll refs
            const navScrollRef = useRef(null);
            const [isDraggingNav, setIsDraggingNav] = useState(false);
            const [navStartX, setNavStartX] = useState(0);
            const [navScrollLeft, setNavScrollLeft] = useState(0);

            // Theme Init
            useEffect(() => {
                const savedTheme = localStorage.getItem('eat_theme') || 'dark';
                setTheme(savedTheme);
                document.documentElement.classList.toggle('dark', savedTheme === 'dark');
            }, []);

            // Time Awareness - 只在初始化时执行一次
            useEffect(() => {
                const hour = new Date().getHours();
                let targetTab = 'all';
                let greet = '今天吃什么';

                if (hour >= 6 && hour < 10) { targetTab = 'breakfast'; greet = '早安，吃顿好的'; }
                else if (hour >= 14 && hour < 17) { targetTab = 'dessert'; greet = '下午茶时间到'; }
                else if (hour >= 22 || hour < 4) { targetTab = 'night'; greet = '深夜了，整点夜宵？'; }
                else { targetTab = 'meal'; greet = '干饭人，干饭魂'; }

                setGreeting(greet);

                // 只在初始化时设置，用户手动切换后不再自动覆盖
                const hasTab = navTabs.find(t => t.id === targetTab);
                if (hasTab && activeTabId === 'all') {
                    setActiveTabId(targetTab);
                }
            }, []); // 空依赖，只执行一次

            const toggleTheme = () => {
                const newTheme = theme === 'dark' ? 'light' : 'dark';
                setTheme(newTheme);
                localStorage.setItem('eat_theme', newTheme);
                document.documentElement.classList.toggle('dark', newTheme === 'dark');
            }

            const toggleMute = () => {
                setIsMuted(!isMuted);
                if (AudioEngine.ctx && AudioEngine.ctx.state === 'running') AudioEngine.ctx.suspend();
                else if (AudioEngine.ctx && AudioEngine.ctx.state === 'suspended') AudioEngine.ctx.resume();
            }

            // Init - 带容错的本地存储读取
            useEffect(() => {
                try {
                    const lp = localStorage.getItem('eat_prefs');
                    if(lp) setPrefs(normalizePrefs(JSON.parse(lp)));
                } catch(e) { console.error('读取偏好设置失败:', e); }

                try {
                    const lh = localStorage.getItem('eat_history');
                    if(lh) setHistory(JSON.parse(lh));
                } catch(e) { console.error('读取历史记录失败:', e); }

                try {
                    const lc = localStorage.getItem('eat_custom');
                    if(lc) setCustomItems(JSON.parse(lc));
                } catch(e) { console.error('读取自定义美食失败:', e); }

                try {
                    const lo = localStorage.getItem('eat_overrides');
                    if(lo) setFoodOverrides(JSON.parse(lo));
                } catch(e) { console.error('读取美食覆盖失败:', e); }

                try {
                    const lt = localStorage.getItem('eat_tabs');
                    if(lt) setNavTabs(JSON.parse(lt));
                } catch(e) { console.error('读取分类标签失败:', e); }
            }, []);

            // Save - 带容错的本地存储保存
            useEffect(() => {
                try { localStorage.setItem('eat_prefs', JSON.stringify(prefs)); }
                catch(e) { console.error('保存偏好设置失败:', e); }
            }, [prefs]);

            useEffect(() => {
                try { localStorage.setItem('eat_history', JSON.stringify(history)); }
                catch(e) { console.error('保存历史记录失败:', e); }
            }, [history]);

            useEffect(() => {
                try { localStorage.setItem('eat_custom', JSON.stringify(customItems)); }
                catch(e) { console.error('保存自定义美食失败:', e); }
            }, [customItems]);

            useEffect(() => {
                try { localStorage.setItem('eat_overrides', JSON.stringify(foodOverrides)); }
                catch(e) { console.error('保存美食覆盖失败:', e); }
            }, [foodOverrides]);

            useEffect(() => {
                try { localStorage.setItem('eat_tabs', JSON.stringify(navTabs)); }
                catch(e) { console.error('保存分类标签失败:', e); }
            }, [navTabs]);

            // Compute Data
            const allItems = useMemo(() => {
                const builtins = FOOD_DATABASE.map(i => foodOverrides[i.id] ? {...i, ...foodOverrides[i.id]} : i);
                return [...builtins, ...customItems];
            }, [customItems, foodOverrides]);

            const generatePool = useCallback(() => {
                const tab = navTabs.find(t=>t.id===activeTabId) || navTabs[0];
                return getRandomBatch(8, prefs, tab, allItems, fuzzySearchTags.includeTags.length > 0 || fuzzySearchTags.excludeTags.length > 0 || (fuzzySearchTags.excludeKeywords && fuzzySearchTags.excludeKeywords.length > 0) ? fuzzySearchTags : null);
            }, [activeTabId, prefs, allItems, navTabs, fuzzySearchTags]);

            useEffect(() => {
                if(!isSpinning) {
                    setItems(generatePool());
                }
            }, [activeTabId, prefs.excludedCategories, prefs.excludedTags, prefs.sessionBannedIds, generatePool]);

            // 模糊搜索处理
            const handleFuzzySearch = (input) => {
                setFuzzySearchInput(input);
                const tags = parseFuzzySearch(input);
                setFuzzySearchTags(tags);
                const suggestedTabId = inferSearchTabId(input, tags);
                if (suggestedTabId && navTabs.some(t => t.id === suggestedTabId)) {
                    setActiveTabId(suggestedTabId);
                }
            };

            // 清除搜索
            const clearFuzzySearch = () => {
                setFuzzySearchInput('');
                setFuzzySearchTags({ includeTags: [], excludeTags: [], excludeKeywords: [] });
            };

            const handleSpin = () => { 
                if(!isSpinning && items.length > 0) { 
                    setIsSpinning(true); 
                    const winnerIndex = Math.floor(Math.random() * items.length);
                    const selectedWinner = items[winnerIndex];
                    setWinner(selectedWinner); 
                } 
            };

            const handleSpinComplete = () => {
                setIsSpinning(false); 
                if(winner) setHistory(h=>[...h,{food:winner, timestamp:Date.now()}]);
            };

            const handleSaveItem = (item) => {
                if(item.id.startsWith('custom_')) {
                    setCustomItems(prev => { const idx=prev.findIndex(i=>i.id===item.id); if(idx>=0){const n=[...prev];n[idx]=item;return n;} return [...prev,item]; });
                } else {
                    setFoodOverrides(prev=>({...prev, [item.id]: item}));
                }
            };

            const banSession = () => {
                if(!winner) return;
                setPrefs(p => ({...p, sessionBannedIds: [...(p.sessionBannedIds||[]), winner.id]}));
                setWinner(null);
                setTimeout(() => handleSpin(), 500);
            }

            // --- Drag to Scroll Handlers ---
            const handleNavMouseDown = (e) => {
                if (!navScrollRef.current) return;
                setIsDraggingNav(true);
                setNavStartX(e.pageX - navScrollRef.current.offsetLeft);
                setNavScrollLeft(navScrollRef.current.scrollLeft);
            };

            const handleNavMouseLeave = () => {
                setIsDraggingNav(false);
            };

            const handleNavMouseUp = () => {
                setIsDraggingNav(false);
            };

            const handleNavMouseMove = (e) => {
                if (!isDraggingNav || !navScrollRef.current) return;
                e.preventDefault();
                const x = e.pageX - navScrollRef.current.offsetLeft;
                const walk = (x - navStartX) * 2;
                navScrollRef.current.scrollLeft = navScrollLeft - walk;
            };

            return (
                <div className="app-shell max-w-[450px] mx-auto bg-gray-50 dark:bg-black text-zinc-900 dark:text-white relative flex flex-col shadow-2xl selection:bg-black selection:text-white dark:selection:bg-white dark:selection:text-black transition-colors duration-300">
                     <div className="absolute top-[-18%] left-[-20%] w-[140%] h-[58%] bg-gradient-to-b from-gray-200/60 dark:from-zinc-800/30 to-transparent blur-3xl pointer-events-none opacity-60"></div>
                     <div className="absolute inset-x-6 top-[138px] h-px bg-gradient-to-r from-transparent via-white/20 to-transparent pointer-events-none"></div>
                     
                     {/* Header */}
                     <header className="app-header-grid compact-header px-5 pt-4 z-10">
                        <div className="shrink-0">
                            <h1 className="compact-title text-[27px] leading-none font-black tracking-tighter">选了么</h1>
                            <p className="compact-subtitle text-[9px] text-zinc-400 dark:text-zinc-500 font-bold tracking-[0.18em] mt-1.5">{greeting}</p>
                        </div>
                        <div className="compact-search z-10">
                            <div className="relative">
                                <Icons.Search className="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-zinc-400 dark:text-zinc-500 pointer-events-none"/>
                                <input
                                    type="text"
                                    value={fuzzySearchInput}
                                    onChange={(e) => handleFuzzySearch(e.target.value)}
                                    placeholder="想吃什么？"
                                    className="compact-search-input ios-glass-input w-full rounded-2xl pl-10 pr-10 py-3 text-[14px] outline-none focus:ring-2 focus:ring-white/25 focus:border-white/30 transition-all text-zinc-900 dark:text-white placeholder:text-zinc-400 dark:placeholder:text-zinc-500"
                                />
                                {fuzzySearchInput && (
                                    <button
                                        onClick={clearFuzzySearch}
                                        className="absolute right-2 top-1/2 -translate-y-1/2 p-1 rounded-full hover:bg-gray-100 dark:hover:bg-white/10 transition-colors"
                                    >
                                        <Icons.X className="w-3.5 h-3.5 text-zinc-400"/>
                                    </button>
                                )}
                            </div>
                        </div>
                        <div className="relative shrink-0">
                            <button onClick={()=>setShowTopMenu(v=>!v)} aria-label="更多操作" title="更多操作" className="ios-glass-soft ios-icon-button w-9 h-9 rounded-full flex items-center justify-center hover:scale-105 active:scale-95 transition-transform"><Icons.Settings className="w-4 h-4"/></button>
                            {showTopMenu && (
                                <div className="top-menu-popover ios-glass">
                                    <button onClick={()=>{setShowTopMenu(false); setEditingItem(null); setModals({...modals, add:true})}} aria-label="添加美食" title="添加美食" className="ios-glass-soft ios-icon-button w-9 h-9 rounded-full flex items-center justify-center hover:scale-105 active:scale-95 transition-transform"><Icons.Plus className="w-4 h-4"/></button>
                                    <button onClick={()=>{setShowTopMenu(false); setModals({...modals, library:true})}} aria-label="美食图鉴" title="美食图鉴" className="ios-glass-soft ios-icon-button w-9 h-9 rounded-full flex items-center justify-center hover:scale-105 active:scale-95 transition-transform"><Icons.BookOpen className="w-4 h-4"/></button>
                                    <button onClick={()=>{setShowTopMenu(false); setModals({...modals, settings:true})}} aria-label="偏好设置" title="偏好设置" className="ios-glass-soft ios-icon-button w-9 h-9 rounded-full flex items-center justify-center hover:scale-105 active:scale-95 transition-transform"><Icons.Settings className="w-4 h-4"/></button>
                                </div>
                            )}
                        </div>
                     </header>

                     {/* Fuzzy Search Bar */}
                     <div className="px-6 z-10">
                        {(fuzzySearchTags.includeTags.length > 0 || fuzzySearchTags.excludeTags.length > 0 || (fuzzySearchTags.excludeKeywords && fuzzySearchTags.excludeKeywords.length > 0)) && (
                            <div className="flex flex-wrap gap-2 mt-2">
                                {fuzzySearchTags.includeTags.map(tag => (
                                    <span key={tag} className="px-2.5 py-1 bg-emerald-50 dark:bg-emerald-950/40 text-emerald-700 dark:text-emerald-300 text-[11px] font-bold rounded-full border border-emerald-200 dark:border-emerald-800/70">
                                        + {tag}
                                    </span>
                                ))}
                                {fuzzySearchTags.excludeTags.map(tag => (
                                    <span key={tag} className="px-2.5 py-1 bg-rose-50 dark:bg-rose-950/40 text-rose-700 dark:text-rose-300 text-[11px] font-bold rounded-full border border-rose-200 dark:border-rose-800/70">
                                        - {tag}
                                    </span>
                                ))}
                                {(fuzzySearchTags.excludeKeywords || []).map(keyword => (
                                    <span key={`keyword-${keyword}`} className="px-2.5 py-1 bg-rose-50 dark:bg-rose-950/40 text-rose-700 dark:text-rose-300 text-[11px] font-bold rounded-full border border-rose-200 dark:border-rose-800/70">
                                        - {keyword}
                                    </span>
                                ))}
                            </div>
                        )}
                     </div>

                     {/* Nav (Fixed Center Alignment) */}
                     <div className="compact-nav z-10 px-4 mt-2.5 w-full">
                        <div className="ios-glass flex items-center justify-between rounded-2xl p-1">
                            <div
                                ref={navScrollRef}
                                className="flex-1 overflow-x-auto nav-scrollbar flex items-center gap-1 min-w-0 cursor-grab active:cursor-grabbing px-1 pb-1"
                                onMouseDown={handleNavMouseDown}
                                onMouseLeave={handleNavMouseLeave}
                                onMouseUp={handleNavMouseUp}
                                onMouseMove={handleNavMouseMove}
                            >
                                {navTabs.map(t => (
                                    <button key={t.id} onClick={()=>!isSpinning&&setActiveTabId(t.id)} className={`compact-nav-button min-w-[66px] px-2.5 py-1.5 rounded-xl text-[11px] font-bold whitespace-nowrap border shrink-0 flex items-center justify-center gap-1 active:scale-95 transition-all ${activeTabId===t.id ? 'ios-nav-active' : 'text-zinc-600 dark:text-zinc-300 border-transparent hover:bg-white/35 dark:hover:bg-white/10'}`}>
                                        {ICON_MAP[t.iconName] || <Icons.Layers className="w-3 h-3"/>}
                                        <span>{t.label}</span>
                                    </button>
                                ))}
                            </div>
                            <div className="w-px h-4 bg-gray-200 dark:bg-white/10 mx-1 shrink-0"></div>
                            <button onClick={()=>setModals({...modals, catManager:true})} aria-label="管理分类" title="管理分类" className="ios-icon-button p-1.5 hover:text-black dark:hover:text-white shrink-0"><Icons.Edit className="w-3.5 h-3.5"/></button>
                        </div>
                     </div>

                     {/* Main Wheel */}
                     <main className="compact-wheel-zone wheel-zone flex-1 flex flex-col items-center justify-center pt-1 pb-1 relative z-0">
                        <div className="relative transition-transform duration-700">
                             <div className="absolute inset-[9%] rounded-full bg-white/10 dark:bg-white/5 blur-3xl pointer-events-none"></div>
                             <Wheel items={items} isSpinning={isSpinning} onSpinComplete={handleSpinComplete} winner={winner} theme={theme} isMuted={isMuted}/>
                        </div>
                        <div className="wheel-action-rail">
                            <button onClick={()=>setItems(generatePool())} disabled={isSpinning} aria-label="换一批候选" title="换一批候选" className="ios-glass-soft ios-icon-button p-3 rounded-full hover:text-black dark:hover:text-white transition-colors"><Icons.Shuffle className="w-4 h-4"/></button>
                            <button onClick={()=>setModals({...modals, history:true})} aria-label="历史记录" title="历史记录" className="ios-glass-soft ios-icon-button p-3 rounded-full hover:text-black dark:hover:text-white transition-colors"><Icons.History className="w-4 h-4"/></button>
                        </div>
                     </main>

                     {/* Footer Controls */}
                     <div className="compact-footer w-full px-6 pb-6 z-20 flex flex-col items-center gap-3 mt-3">
                        <button onClick={handleSpin} disabled={isSpinning||items.length===0} className={`compact-spin-button w-full max-w-[280px] rounded-2xl px-5 py-4 text-[15px] font-black tracking-[0.24em] transition-all duration-300 border ${isSpinning || items.length===0 ? 'bg-zinc-200 dark:bg-zinc-900 text-zinc-400 dark:text-zinc-600 border-transparent' : 'bg-zinc-950 dark:bg-white text-white dark:text-black border-zinc-950 dark:border-white shadow-[0_16px_45px_rgba(0,0,0,0.28)] dark:shadow-[0_0_35px_rgba(255,255,255,0.16)] hover:scale-[1.02] active:scale-[0.98]'}`}>开始旋转</button>
                     </div>

                     {/* Modals */}
                     {!isSpinning && winner && <ResultCard winner={winner} onClose={()=>setWinner(null)} onRetry={()=>{setWinner(null); handleSpin();}} isFavorite={(prefs.favoriteItemIds||[]).includes(winner?.id)} onToggleFavorite={()=>setPrefs(p=>{const favs = p.favoriteItemIds || []; return {...p, favoriteItemIds: favs.includes(winner.id)?favs.filter(x=>x!==winner.id):[...favs,winner.id]};})} theme={theme} onBanSession={banSession} />}
                     
                     <Settings isOpen={modals.settings} onClose={()=>setModals({...modals, settings:false})} prefs={prefs} updatePrefs={setPrefs} allFoodItems={allItems} theme={theme} toggleTheme={toggleTheme} isMuted={isMuted} toggleMute={toggleMute} />
                     <History isOpen={modals.history} onClose={()=>setModals({...modals, history:false})} history={history} onClear={()=>setHistory([])} />
                     <FoodLibrary isOpen={modals.library} onClose={()=>setModals({...modals, library:false})} items={allItems} onEdit={i=>{setEditingItem(i); setModals({...modals, add:true})}} favs={prefs.favoriteItemIds || []} onToggleFav={id=>setPrefs(p=>{const favs = p.favoriteItemIds || []; return {...p, favoriteItemIds:favs.includes(id)?favs.filter(x=>x!==id):[...favs,id]};})} navTabs={navTabs}/>
                     <CategoryManager isOpen={modals.catManager} onClose={()=>setModals({...modals, catManager:false})} tabs={navTabs} onUpdateTabs={setNavTabs} />
                     <AddFoodModal isOpen={modals.add} onClose={()=>setModals({...modals, add:false})} onAdd={handleSaveItem} initialItem={editingItem} navTabs={navTabs} />
                </div>
            );
        };

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
